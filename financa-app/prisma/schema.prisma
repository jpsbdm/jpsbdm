generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id           Int      @id @default(autoincrement())
  date         DateTime
  description  String
  bank         String
  toBank       String?  // destino em transferências
  type         String   // 'Despesa' | 'Receita' | 'Transferência'
  category     String
  subcategory  String   @default("")
  empresa      String   // 'Pessoal' | 'Marmitas' | 'Personal Chef'
  amount       Float
  notes        String   @default("")
  exported     Boolean  @default(false)
  importedFrom String?
  externalRef  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id             Int      @id @default(autoincrement())
  name           String
  type           String   // 'corrente' | 'poupanca' | 'credito' | 'emprestimo' | 'dinheiro' | 'investimento'
  color          String   @default("#0D9488")
  initialBalance Float    @default(0)
  initialDate    DateTime @default(now())
  creditLimit    Float?   // para cartões de crédito
  interestRate   Float?   // % ao ano (para crédito/empréstimo)
  minimumPayment Float?   // parcela mínima mensal
  dueDay         Int?     // dia do vencimento (1-31)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Budget {
  id       Int    @id @default(autoincrement())
  month    Int
  year     Int
  category String
  amount   Float

  @@unique([month, year, category])
}

model SavingsGoal {
  id            Int      @id @default(autoincrement())
  name          String
  currentAmount Float    @default(0)
  targetAmount  Float
  weeklyContrib Float    @default(0)
  startDate     DateTime
  updatedAt     DateTime @updatedAt
}

model AllowedDevice {
  id          Int      @id @default(autoincrement())
  fingerprint String   @unique
  name        String
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AppSession {
  id        String   @id
  token     String   @unique
  deviceId  Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Settings {
  id              Int    @id @default(1)
  banks           String @default("[]")
  categories      String @default("{}")
  initialBalances String @default("{}")
}
